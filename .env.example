# ── App ───────────────────────────────────────────────────────────────────────
ENV=prod
DEBUG=false
APP_NAME="Parkinson's Voice Detection API"
PUBLIC_BASE_URL=https://parkinsons.example.com
API_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────────────────────
# Production: PostgreSQL via asyncpg
DATABASE_URL=postgresql+asyncpg://app:CHANGE_ME@postgres:5432/parkinsons
# Development (SQLite — zero dependencies):
# DATABASE_URL=sqlite+aiosqlite:///./dev.db

DB_POOL_SIZE=10
DB_POOL_TIMEOUT_S=30

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth (admin only) ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Generate with: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your-password'))"
ADMIN_PASSWORD_HASH=$2b$12$CHANGE_ME_REPLACE_WITH_REAL_HASH
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=CHANGE_ME_32_RANDOM_BYTES_BASE64
JWT_ALGO=HS256
JWT_TTL_MIN=720

# ── Rate limits ───────────────────────────────────────────────────────────────
RL_PREDICT_PER_MIN=60
RL_AUDIO_PER_MIN=10
RL_BATCH_PER_MIN=5

# ── Audio ─────────────────────────────────────────────────────────────────────
AUDIO_MAX_BYTES=5242880
AUDIO_MAX_DURATION_S=30.0
AUDIO_TARGET_SR=22050

# ── Batch ─────────────────────────────────────────────────────────────────────
BATCH_MAX_ROWS=10000
BATCH_MAX_BYTES=2097152

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=https://CHANGE_ME@o0.ingest.sentry.io/0
PROMETHEUS_ENABLED=true
LOG_LEVEL=INFO

# ── Privacy ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Rotate nightly via cron (or leave static for dev)
HASH_DAILY_SALT=CHANGE_ME_32_HEX_CHARS

# ── LLM ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_CHANGE_ME
GEMINI_API_KEY=AIzaSy_CHANGE_ME
OPENROUTER_API_KEY=sk-or-CHANGE_ME

LLM_PRIMARY_PROVIDER=groq
LLM_FALLBACK_PROVIDER=gemini
LLM_TIMEOUT_S=30
LLM_DAILY_TOKEN_BUDGET=500000

# ── Frontend (baked at build time via Vite) ───────────────────────────────────
# VITE_API_BASE_URL=https://parkinsons.example.com/api/v1
